// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StatusStok {
  aman
  waspada
  habis
  belum_terjadi
}

// ========================================
// 1. BAHAN BAKU (MASTER)
// ========================================
model BahanBaku {
  id          String   @id @default(cuid())
  nama        String
  satuan      String   // Kg, Pcs, Lbr, Ml, Gr
  harga       Int      // Harga per satuan
  stok        Float    @default(0)  // Stok saat ini
  stokMinimal Float    @default(0)  // Target minimal stok
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  produkDetail ProdukBahanBaku[]
  pembelian   PembelianBahanBaku[]

  @@unique([nama])
  @@index([nama])
}

// ========================================
// 2. PRODUK
// ========================================
model Produk {
  id          String   @id @default(cuid())
  nama        String
  sku         String   @unique
  hpp         Int      // Harga Pokok Produksi (dari resep)
  hargaJual   Int      // Harga jual per porsi
  stok        Float    @default(0)  // Stok produk (dihitung dari bahan baku)
  targetStok  Float    @default(0)  // Target minimal stok
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bahanBaku   ProdukBahanBaku[]
  penjualan   Penjualan[]

  @@index([sku])
  @@index([nama])
}

// ========================================
// 3. BAHAN BAKU PER PRODUK (RESEP)
// ========================================
model ProdukBahanBaku {
  id          String   @id @default(cuid())
  produkId    String
  bahanBakuId String
  qty         Float    // Qty bahan baku per porsi produk
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  produk      Produk    @relation(fields: [produkId], references: [id], onDelete: Cascade)
  bahanBaku   BahanBaku @relation(fields: [bahanBakuId], references: [id], onDelete: Cascade)

  @@unique([produkId, bahanBakuId])
  @@index([produkId])
  @@index([bahanBakuId])
}

// ========================================
// 4. PEMBELIAN BAHAN BAKU
// ========================================
model PembelianBahanBaku {
  id          String   @id @default(cuid())
  tanggal     DateTime @default(now())
  bahanBakuId String
  qty         Float
  harga       Int      // Harga saat pembelian
  total       Int      // qty × harga
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bahanBaku   BahanBaku @relation(fields: [bahanBakuId], references: [id], onDelete: Cascade)

  @@index([tanggal])
  @@index([bahanBakuId])
}

// ========================================
// 5. PENJUALAN
// ========================================
model Penjualan {
  id          String   @id @default(cuid())
  tanggal     DateTime @default(now())
  produkId    String
  qty         Float
  hargaJual   Int      // Snapshot harga jual saat transaksi
  hpp         Int      // Snapshot HPP saat transaksi
  profit      Int      // (hargaJual - hpp) × qty
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  produk      Produk @relation(fields: [produkId], references: [id], onDelete: Cascade)

  @@index([tanggal])
  @@index([produkId])
}

// ========================================
// 6. LAPORAN BULANAN (EXISTING)
// ========================================
model LaporanBulanan {
  id                  String   @id @default(cuid())
  bulan               DateTime
  menu                String
  qtyProduksi         Int
  costPerPortion      Int
  jumlahCost          Int
  overhead            Int      @default(0)
  gaji                Int      @default(0)
  labaKotor           Int
  profit              Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([bulan])
  @@index([menu])
}

// ========================================
// 7. PENGGALIAN (EXISTING)
// ========================================
model Penggajian {
  id                  String   @id @default(cuid())
  nama                String
  posisi              String   // "Kitchen" atau "Seller"
  gaji                Int
  tanggal_penggajian  DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tanggal_penggajian])
  @@index([posisi])
  @@index([nama])
}

// ========================================
// 8. ASSET & OVERHEAD (EXISTING)
// ========================================
model Asset {
  id          String   @id @default(cuid())
  name        String
  category    String
  quantity    Int
  price       Int
  total       Int
  perMonth    Int
  status      String   @default("Baik") // Baik, Rusak, Perbaikan
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([status])
}