// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StatusStok {
  aman
  waspada
  habis
  belum_terjadi
}

// ========================================
// 1. BAHAN BAKU (MASTER)
// ========================================
model BahanBaku {
  id          String   @id @default(cuid())
  nama        String
  satuan      String   // g, kg, pcs, lbr, ml
  harga       Int      // Harga per satuan
  stok        Float    @default(0)
  stokMinimal Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  produkDetail   ProdukBahanBaku[]
  pembelianBahan PembelianBahanBaku[]

  @@unique([nama])
  @@index([nama])
}

// ========================================
// 2. PRODUK
// ========================================
model Produk {
  id          String   @id @default(cuid())
  nama        String
  sku         String   @unique
  hpp         Int
  hargaJual   Int
  stok        Float    @default(0)
  targetStok  Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bahanBaku   ProdukBahanBaku[]
  penjualan   Penjualan[]

  @@index([sku])
  @@index([nama])
}

// ========================================
// 3. BAHAN BAKU PER PRODUK (RESEP)
// ========================================
model ProdukBahanBaku {
  id          String   @id @default(cuid())
  produkId    String
  bahanBakuId String
  qty         Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  produk      Produk    @relation(fields: [produkId], references: [id], onDelete: Cascade)
  bahanBaku   BahanBaku @relation(fields: [bahanBakuId], references: [id], onDelete: Cascade)

  @@unique([produkId, bahanBakuId])
  @@index([produkId])
  @@index([bahanBakuId])
}

// ========================================
// 4. PEMBELIAN BAHAN BAKU (KHUSUS BAHAN BAKU)
// ========================================
model PembelianBahanBaku {
  id          String   @id @default(cuid())
  tanggal     DateTime @default(now())
  bahanBakuId String
  qty         Float
  harga       Int      // Harga per satuan saat pembelian
  total       Int      // qty × harga
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bahanBaku   BahanBaku @relation(fields: [bahanBakuId], references: [id], onDelete: Cascade)

  @@index([tanggal])
  @@index([bahanBakuId])
}

// ========================================
// 5. PENJUALAN
// ========================================
model Penjualan {
  id          String   @id @default(cuid())
  tanggal     DateTime @default(now())
  produkId    String
  qty         Float
  hargaJual   Int
  hpp         Int
  profit      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  produk      Produk @relation(fields: [produkId], references: [id], onDelete: Cascade)

  @@index([tanggal])
  @@index([produkId])
}

// ========================================
// 6. LAPORAN BULANAN
// ========================================
model LaporanBulanan {
  id                  String   @id @default(cuid())
  bulan               DateTime
  qtyProduksi         Int
  costPerPortion      Int
  jumlahCost          Int
  overhead            Int      @default(0)
  gaji                Int      @default(0)
  labaKotor           Int
  profit              Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([bulan])
}

// ========================================
// 7. PENGGALIAN
// ========================================
model Penggajian {
  id                  String   @id @default(cuid())
  nama                String
  posisi              String
  gaji                Int
  tanggal_penggajian  DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tanggal_penggajian])
  @@index([posisi])
  @@index([nama])
}

// ========================================
// 8. ASSET & OVERHEAD
// ========================================
model Asset {
  id          String   @id @default(cuid())
  name        String
  category    String
  quantity    Int
  price       Int
  total       Int
  perMonth    Int
  status      String   @default("Baik")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([status])
}

// ========================================
// 9. PEMBELIAN (FLEKSIBEL - TANPA KATEGORI)
// ========================================
model Pembelian {
  id          String   @id @default(cuid())
  tanggal     DateTime @default(now())
  nama        String
  detail      String?
  qty         Float    @default(0)
  harga       Int      @default(0)
  total       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tanggal])
  @@index([nama])
}

// ========================================
// 10. TARGET COSTING (BERDIRI SENDIRI)
// ========================================
model TargetCosting {
  id            String   @id @default(cuid())
  produkId      String
  bulan         DateTime
  
  // Target komponen (hasil perhitungan)
  targetBahanBaku      Int @default(0)
  targetOverhead       Int @default(0)
  targetGaji           Int @default(0)
  
  // Persentase (input user) - per produk
  persentaseOverhead   Float @default(0)  // Contoh: 70
  persentaseGaji       Float @default(0)  // Contoh: 15
  
  // Harga bahan baku yang dipilih user (JSON)
  // { "bahanBakuId": harga_baru, ... }
  hargaBahanBaku       Json?  @default("{}")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([produkId, bulan])
  @@index([produkId])
  @@index([bulan])
}